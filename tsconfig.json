{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",

    "lib": ["ES2022"],

    "types": ["node"],

    "declaration": true,
    "removeComments": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "sourceMap": true,
    "outDir": "./dist",

    "incremental": true,

    "skipLibCheck": true,

    "strict": true,

    "forceConsistentCasingInFileNames": true,
    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ]
  }
}